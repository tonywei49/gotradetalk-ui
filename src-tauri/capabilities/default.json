{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        "https://*",
        "https://*:*",
        "http://localhost:*",
        "http://127.0.0.1:*"
      ]
    },
    "sql:default",
    "sql:allow-execute"
  ]
}
